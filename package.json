{
  "name": "best-value-tuition-sg",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:api\"",
    "dev:web": "cd apps/web && bun run dev",
    "dev:api": "cd apps/api && bun run dev",
    "build": "cd apps/api && bun run build && cd ../web && bun run build",
    "typecheck": "cd apps/api && bun run typecheck && cd ../web && bun run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
